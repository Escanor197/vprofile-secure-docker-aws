# EC2 private IP. Do not use 0.0.0.0 for the hardened AWS deployment.
APP_BIND_IP=10.0.2.10
APP_PORT=8080

# Local image names. Replace these with private registry references when needed.
APP_IMAGE=vprofile-app:secure
DB_IMAGE=vprofile-db:secure
RABBITMQ_IMAGE=vprofile-rabbitmq:secure
MEMCACHED_IMAGE=vprofile-memcached:secure
ELASTICSEARCH_IMAGE=vprofile-elasticsearch:5.6.4

# Resource limits for a host with at least 4 vCPU and 16 GiB RAM.
APP_MEMORY_LIMIT=1536m
APP_CPU_LIMIT=1.50
DB_MEMORY_LIMIT=2560m
DB_CPU_LIMIT=1.50
RABBITMQ_MEMORY_LIMIT=1024m
RABBITMQ_CPU_LIMIT=1.00
MEMCACHED_MEMORY_LIMIT=256m
MEMCACHED_CPU_LIMIT=0.50
ELASTICSEARCH_MEMORY_LIMIT=2048m
ELASTICSEARCH_CPU_LIMIT=1.50
